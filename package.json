{
  "name": "@khou/trupe",
  "version": "0.1.0",
  "description": "Git-native team orchestration for coding agents: tasks, proposals, approvals, and audit in your repo.",
  "type": "module",
  "bin": {
    "trupe": "./bin/trupe.js"
  },
  "files": [
    "bin",
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
